# ---- SPA (Vite, public, read via import.meta.env) ----
VITE_API_BASE_URL=/api
# WebSocket ORIGIN only (no path). The Socket.IO client sets the engine path
# `/v1/tracking/socket.io/` itself. Local-via-gateway: ws://localhost:8080
VITE_WS_URL=wss://api.example.com
VITE_MAP_STYLE_URL=https://tiles.openfreemap.org/styles/dark

# ---- Vercel serverless functions (server-side) ----
# Public gateway origin the auth BFF calls. Also hardcoded in vercel.json's rewrite.
GATEWAY_URL=https://api.example.com

# Contact string folded into the Nominatim User-Agent (their usage policy). Optional.
GEOCODE_CONTACT=you@example.com

# ---- Demo (tests/demo/full-lifecycle.demo.ts, local-only, not CI) ----
# Throwaway local-stack seed accounts (see local-stack/RUNBOOK.md). The demo
# spec falls back to these exact seeded dev accounts if these are unset.
DEMO_CUSTOMER_EMAIL=customer@logistics.local
DEMO_CUSTOMER_PASSWORD=Customer12345!
DEMO_DRIVER_EMAIL=driver@logistics.local
DEMO_DRIVER_PASSWORD=Driver12345!
