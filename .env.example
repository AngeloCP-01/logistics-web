# ---- SPA (Vite, public, read via import.meta.env) ----
VITE_API_BASE_URL=/api
# WebSocket ORIGIN only (no path). The Socket.IO client sets the engine path
# `/v1/tracking/socket.io/` itself. Local-via-gateway: ws://localhost:8080
VITE_WS_URL=wss://api.example.com
VITE_MAP_STYLE_URL=https://tiles.openfreemap.org/styles/dark

# ---- Vercel serverless functions (server-side) ----
# Public gateway origin the auth BFF calls. Also hardcoded in vercel.json's rewrite.
GATEWAY_URL=https://api.example.com
