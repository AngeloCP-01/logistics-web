{
  "name": "logistics-web",
  "private": true,
  "version": "0.7.1",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "lint": "eslint .",
    "typecheck": "tsc -b --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "gen:api": "openapi-typescript ../logistics-contracts/openapi/auth-service.yaml -o ./src/shared/api/types/auth.d.ts && openapi-typescript ../logistics-contracts/openapi/order-service.yaml -o ./src/shared/api/types/order.d.ts && openapi-typescript ../logistics-contracts/openapi/user-service.yaml -o ./src/shared/api/types/user.d.ts && openapi-typescript ../logistics-contracts/openapi/tracking-service.yaml -o ./src/shared/api/types/tracking.d.ts && openapi-typescript ../logistics-contracts/openapi/dispatch-service.yaml -o ./src/shared/api/types/dispatch.d.ts && openapi-typescript ../logistics-contracts/openapi/notification-service.yaml -o ./src/shared/api/types/notification.d.ts",
    "demo:e2e": "playwright test --config=playwright.demo.config.ts"
  },
  "dependencies": {
    "@hookform/resolvers": "^3.9.0",
    "@radix-ui/react-dialog": "^1.1.16",
    "@radix-ui/react-label": "^2.1.9",
    "@radix-ui/react-separator": "^1.1.9",
    "@radix-ui/react-slot": "^1.2.5",
    "@tanstack/react-query": "^5.59.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.17.0",
    "maplibre-gl": "^4.7.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-hook-form": "^7.53.0",
    "react-map-gl": "^7.1.7",
    "react-router-dom": "^7.0.0",
    "recharts": "^2.15.4",
    "socket.io-client": "^4.8.0",
    "sonner": "^1.5.0",
    "tailwind-merge": "^3.6.0",
    "tailwindcss-animate": "^1.0.7",
    "zod": "^3.23.8",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.48.0",
    "@testing-library/jest-dom": "^6.5.0",
    "@testing-library/react": "^16.0.1",
    "@testing-library/user-event": "^14.5.2",
    "@types/node": "^20.16.0",
    "@types/react": "^18.3.10",
    "@types/react-dom": "^18.3.0",
    "@vercel/node": "^3.2.0",
    "@vitejs/plugin-react": "^4.3.2",
    "autoprefixer": "^10.4.20",
    "eslint": "^9.11.0",
    "jsdom": "^25.0.1",
    "msw": "^2.4.9",
    "openapi-typescript": "^7.4.0",
    "postcss": "^8.4.47",
    "prettier": "^3.3.3",
    "tailwindcss": "^3.4.13",
    "typescript": "^5.6.2",
    "typescript-eslint": "^8.8.0",
    "vite": "^6.0.0",
    "vitest": "^3.2.0"
  }
}
